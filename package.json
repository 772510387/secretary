    "brain:smoke": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/brain-smoke.ts",
    "ask": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/ask.ts",
    "plan:smoke": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/plan-smoke.ts",
    "research:smoke": "tsx scripts/dev/research-smoke.ts",
    "agent": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/agent.ts",
    "agent:server": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/agent-server.ts",
    "trade": "tsx scripts/dev/trade.ts",
