{
  "name": "secretary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A-share trading assistant architecture with deterministic risk control and pluggable AI research brains.",
  "scripts": {
    "doctor": "tsx scripts/dev/doctor.ts",
    "check:docs": "node -e \"console.log('docs scaffold present; implement validation later')\"",
    "seed:paper": "tsx scripts/dev/seed-paper-account.ts",
    "research:once": "tsx scripts/dev/research-once.ts",
    "brain:smoke": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/brain-smoke.ts",
    "ask": "cross-env NODE_USE_ENV_PROXY=1 tsx scripts/dev/ask.ts",
    "trade": "tsx scripts/dev/trade.ts",
    "wechat:test": "tsx scripts/dev/wechat-test.ts",
    "sentinel:dev": "tsx scripts/dev/market-sentinel-daemon.ts",
    "manual-confirm:dev": "tsx scripts/dev/manual-confirm.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
