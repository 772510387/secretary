# Runtime
NODE_ENV=development
TIMEZONE=Asia/Shanghai
LIVE_TRADING=false

# Brain provider: openai | gemini | dashscope | mock
BRAIN_PROVIDER=mock
# Optional: provider used automatically when the primary fails (e.g. dashscope).
BRAIN_FALLBACK_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Set to 1 to allow `npm run brain:smoke` to make a real outbound LLM call.
# Default (unset) keeps real providers offline; only the mock provider runs without it.
BRAIN_NETWORK_SMOKE=

# Behind a proxy (e.g. to reach Gemini from mainland China)? Set HTTP_PROXY/HTTPS_PROXY
# and run on Node >= 24. `npm run brain:smoke` already sets NODE_USE_ENV_PROXY=1 so
# Node's built-in fetch honors the proxy. For other entry points export NODE_USE_ENV_PROXY=1
# yourself (it must be set before Node starts; it cannot be set from .env).
# HTTPS_PROXY=http://127.0.0.1:7890

# WeCom (Enterprise WeChat) group-bot push notifications (one-way, project -> your group).
# Paste the whole group-bot webhook URL, e.g.
# https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx
# Then test with: WECHAT_NETWORK_SEND=1 npm run wechat:test
WECOM_BOT_WEBHOOK_URL=
# Set to 1 to let the sentinel daemon push start/stop (and heartbeat) status to WeCom.
WECOM_NOTIFY=
# Optional: heartbeat push interval in ms (>=60000). Empty/omitted = only start+stop pings.
WECOM_HEARTBEAT_MS=

# Market data provider
MARKET_PROVIDER=tencent
TUSHARE_TOKEN=

# Storage
SECRETARY_DATA_DIR=./data
SECRETARY_MEMORY_DIR=./memory

# Future broker integration
BROKER_PROVIDER=paper
BROKER_ACCOUNT_ID=
