# Runtime
NODE_ENV=development
TIMEZONE=Asia/Shanghai
LIVE_TRADING=false

# Brain provider: openai | gemini | dashscope | mock
BRAIN_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=

# Market data provider
MARKET_PROVIDER=tencent
TUSHARE_TOKEN=

# Storage
SECRETARY_DATA_DIR=./data
SECRETARY_MEMORY_DIR=./memory

# Future broker integration
BROKER_PROVIDER=paper
BROKER_ACCOUNT_ID=
