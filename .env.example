# Runtime
NODE_ENV=development
TIMEZONE=Asia/Shanghai
LIVE_TRADING=false

# Brain provider: openai | gemini | dashscope | mock
BRAIN_PROVIDER=mock
# Optional: provider used automatically when the primary fails (e.g. dashscope).
BRAIN_FALLBACK_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
# Per-request brain timeout (ms). Large generations need more than the old 30s.
BRAIN_TIMEOUT_MS=60000
# Optional output cap. Bounds huge/runaway generations; truncation is surfaced as a clear error.
BRAIN_MAX_TOKENS=

# Per-Beijing-day spend caps for the always-on daemon (alarms + sentinel + research).
# Empty = unlimited. Guards against overnight cost runaway. Counters reset at the day boundary.
BRAIN_DAILY_LIMIT=
RESEARCH_DAILY_LIMIT=
SEARCH_DAILY_LIMIT=

# Set to 1 to allow `npm run brain:smoke` to make a real outbound LLM call.
# Default (unset) keeps real providers offline; only the mock provider runs without it.
BRAIN_NETWORK_SMOKE=

# Behind a proxy (e.g. to reach Gemini from mainland China)? Set HTTP_PROXY/HTTPS_PROXY
# and run on Node >= 24. `npm run brain:smoke` already sets NODE_USE_ENV_PROXY=1 so
# Node's built-in fetch honors the proxy. For other entry points export NODE_USE_ENV_PROXY=1
# yourself (it must be set before Node starts; it cannot be set from .env).
# HTTPS_PROXY=http://127.0.0.1:7890

# (WeCom / Enterprise WeChat push has been removed — external push goes to Feishu only;
#  see FEISHU_NOTIFY below.)

# Web search (backend-executed, read-only; results are fed to the model as context).
# The model never gets an autonomous web tool. Used by: npm run ask -- --web "..."
SEARCH_PROVIDER=none
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=5

# Personal-WeChat two-way bot bridge (wechaty). Install when you want it:
#   npm i wechaty <puppet>   e.g. wechaty-puppet-wcferry (Windows) / wechaty-puppet-padlocal.
# Then: npm run wechat:bot  (scan the printed QR with a — ideally secondary — WeChat account).
WECHATY_PUPPET=
WECHATY_PUPPET_TOKEN=
# Owner allowlist (comma-separated wechat ids/names). Empty = anyone can ask (read-only),
# but destructive ops (reset/seed) stay disabled until you list your own id/name.
WECHAT_ALLOWED_USERS=

# Feishu (Lark) two-way bot over long-connection (WebSocket): official API, no ban risk,
# and NO public IP / tunnel needed (the bot dials out). Recommended for chat.
# Create a 自建应用 at https://open.feishu.cn -> App ID/Secret -> Event subscription in
# 长连接 mode -> subscribe im.message.receive_v1 -> add im:message permissions. Then: npm run feishu:bot
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Owner allowlist (comma-separated Feishu open_id). Empty = read-only for all; add your open_id
# (printed in the bot log on your first DM) to allow reset/seed.
FEISHU_ALLOWED_USERS=
# Opt-in: proactively push alarm/sentinel notifications INTO Feishu (every alarm node's
# summary + anomaly alerts). Needs FEISHU_APP_ID/SECRET + the app's im:message:send_as_bot
# (主动发消息) permission. Set to 1 to enable.
FEISHU_NOTIFY=
# open_ids that receive the proactive pushes (comma-separated). Empty = falls back to
# FEISHU_ALLOWED_USERS. This is who gets the morning/intraday/closing summaries in Feishu.
FEISHU_PUSH_USERS=

# Deep research engine. "mock" = local placeholder; "trading_agents_cn" = real
# multi-agent analysis (DashScope Qwen) via the Python bridge. The deep_research
# intent ("深度分析/该不该买/下周怎么操作") routes here; one run takes minutes + tokens.
# Setup once: in the TradingAgents-CN repo run `uv sync` (or install requirements.txt),
# then point these at its venv python + the bridge script + repo dir.
RESEARCH_PROVIDER=mock
# e.g. D:/Project/main/TradingAgents-CN/.venv/Scripts/python.exe
RESEARCH_COMMAND=
# e.g. D:/Project/main/TradingAgents-CN/secretary_bridge.py
RESEARCH_SCRIPT=
# e.g. D:/Project/main/TradingAgents-CN
RESEARCH_CWD=
RESEARCH_TIMEOUT_MS=600000
RESEARCH_DEEP_MODEL=qwen-plus
RESEARCH_QUICK_MODEL=qwen-turbo
# Which analyst agents to run (comma-separated); fewer = faster/cheaper.
RESEARCH_ANALYSTS=market,fundamentals,news

# Market data provider
MARKET_PROVIDER=tencent
TUSHARE_TOKEN=

# Storage
SECRETARY_DATA_DIR=./data
SECRETARY_MEMORY_DIR=./memory

# Future broker integration
BROKER_PROVIDER=paper
BROKER_ACCOUNT_ID=
