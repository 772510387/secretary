{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secretary.local/schemas/audit-event.schema.json",
  "title": "AuditEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "occurredAt",
    "actor",
    "action",
    "subject",
    "severity",
    "result",
    "message"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "system", "brain", "broker", "scheduler", "api", "cli"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
        }
      }
    },
    "action": {
      "type": "string",
      "enum": ["read", "write", "suggest", "validate", "order", "notify", "config", "error"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "account",
            "position",
            "trade",
            "order",
            "memory",
            "config",
            "report",
            "risk",
            "brain",
            "provider",
            "storage"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": ["debug", "info", "warning", "critical"]
    },
    "result": {
      "type": "string",
      "enum": ["success", "failure", "rejected", "skipped"]
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "metadata": {
      "type": "object"
    }
  }
}

